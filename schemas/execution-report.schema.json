{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Report Act",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "who",
    "did",
    "this",
    "confirmed_by",
    "if_ok",
    "if_doubt",
    "if_not",
    "status"
  ],
  "properties": {
    "who": {
      "type": "string",
      "minLength": 1
    },
    "did": {
      "const": "report_execution_result"
    },
    "this": {
      "type": "object",
      "required": [
        "workorder_id",
        "exit_code",
        "secret_redacted"
      ],
      "properties": {
        "workorder_id": {
          "type": "string"
        },
        "exit_code": {
          "type": "integer"
        },
        "stdout_ref": {
          "type": "string"
        },
        "stderr_ref": {
          "type": "string"
        },
        "diff_hash": {
          "type": "string"
        },
        "secret_redacted": {
          "const": true
        }
      }
    },
    "when": {
      "type": "string",
      "format": "date-time"
    },
    "confirmed_by": {
      "type": "object"
    },
    "if_ok": {
      "type": "object"
    },
    "if_doubt": {
      "type": "object"
    },
    "if_not": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "runtime_envelope": {
      "type": "object"
    },
    "previous_act_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_state": {
      "enum": [
        "declared",
        "observed",
        "inconclusive",
        "missing",
        "rejected"
      ]
    },
    "promotion_state": {
      "enum": [
        "candidate",
        "projected",
        "trusted",
        "blocked",
        "rejected"
      ]
    }
  }
}
