{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LogLine Lab Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["lab_id", "profile", "semantic_write_spine", "projection_surface", "canon_refs", "hooks", "benches"],
  "properties": {
    "lab_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"},
    "profile": {"type": "string", "minLength": 1},
    "semantic_write_spine": {"const": "ops.logline_acts"},
    "projection_surface": {"const": "supabase"},
    "canon_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "hooks": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "benches": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
