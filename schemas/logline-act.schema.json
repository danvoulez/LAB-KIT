{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LogLine Act",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "who",
    "did",
    "this",
    "confirmed_by",
    "if_ok",
    "if_doubt",
    "if_not",
    "status"
  ],
  "properties": {
    "who": {
      "type": "string",
      "minLength": 1
    },
    "did": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_:.\\-]*$"
    },
    "this": {
      "type": "object"
    },
    "when": {
      "type": "string",
      "format": "date-time"
    },
    "confirmed_by": {
      "type": "object"
    },
    "if_ok": {
      "type": "object"
    },
    "if_doubt": {
      "type": "object"
    },
    "if_not": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "runtime_envelope": {
      "type": "object"
    },
    "previous_act_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "evidence_state": {
      "enum": [
        "declared",
        "observed",
        "inconclusive",
        "missing",
        "rejected"
      ]
    },
    "promotion_state": {
      "enum": [
        "candidate",
        "projected",
        "trusted",
        "blocked",
        "rejected"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "did": {
            "const": "prepare_receipt_candidate"
          }
        },
        "required": [
          "did"
        ]
      },
      "then": {
        "properties": {
          "this": {
            "required": [
              "claim",
              "scope_closed",
              "scope_not_closed",
              "evidence_refs"
            ],
            "properties": {
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  ]
}
