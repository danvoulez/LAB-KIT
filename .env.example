# Required for commands that touch the Supabase/Postgres act spine.
SUPABASE_DB_URL=postgres://postgres:postgres@localhost:54322/postgres
# Optional HTTP daemon bind address.
LABD_BIND=127.0.0.1:8787
# Safety defaults: semantic writes only to ops.logline_acts.
MINILAB_SAFE_MODE=true
MINILAB_DRY_RUN=true
MINILAB_ALLOW_DB_WRITE=false
MINILAB_ALLOW_PROVIDER_MUTATION=false
